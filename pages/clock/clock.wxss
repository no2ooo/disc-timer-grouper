/* pages/clock/clock.wxss - 翻页时钟 */

.clock-page {
  width: 100vw;
  height: 100vh;
  background: #0a0a0a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.clock-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
}

/* 横屏缩放交由 .clock-wrapper 的内联 transform: scale() 动态控制，
   此处不再写死 scale，避免数字溢出屏外。 */
.clock-wrapper-landscape {
}

.clock-face {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.digit-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

/* 卡片容器：相对定位，承载静态层与动画层 */
.digit-card {
  width: 84rpx;
  height: 132rpx;
  position: relative;
  margin-left: 4rpx;
  margin-right: 4rpx;
  perspective: 400rpx;
}

/* 半片容器：静态与动画层共享基础定位 */
.digit-half {
  position: absolute;
  left: 0;
  width: 100%;
  height: 66rpx;
  overflow: hidden;
  background: #1f1f1f;
  backface-visibility: hidden;
}

/* 静态上半片 */
.digit-top-static {
  top: 0;
  border-radius: 16rpx 16rpx 0 0;
  z-index: 1;
}

/* 静态下半片 */
.digit-bottom-static {
  bottom: 0;
  border-radius: 0 0 16rpx 16rpx;
  z-index: 1;
}

/* 分隔黑线 */
.digit-sep {
  position: absolute;
  left: 0;
  top: 66rpx;
  width: 100%;
  height: 2rpx;
  background: #0a0a0a;
  z-index: 5;
}

/* 动画上半片：显示旧值，向下翻走 */
.digit-top-flip {
  top: 0;
  border-radius: 16rpx 16rpx 0 0;
  transform-origin: bottom center;
  z-index: 3;
}

/* 动画下半片：显示新值，从下方翻入 */
.digit-bottom-flip {
  bottom: 0;
  border-radius: 0 0 16rpx 16rpx;
  transform-origin: top center;
  transform: rotateX(90deg);
  z-index: 3;
}

/* 动画触发类 */
.animating-top {
  animation: flipTop 0.35s ease-in forwards;
}

.animating-bottom {
  animation: flipBottom 0.35s ease-in forwards;
}

@keyframes flipTop {
  0% { transform: rotateX(0); }
  100% { transform: rotateX(-90deg); }
}

@keyframes flipBottom {
  0% { transform: rotateX(90deg); }
  100% { transform: rotateX(0); }
}

/* 数字文字：绝对定位 + 整卡高度，配合半片 overflow:hidden 实现裁剪 */
.digit-text {
  position: absolute;
  left: 0;
  width: 100%;
  height: 132rpx;
  line-height: 132rpx;
  font-size: 132rpx;
  font-weight: 700;
  font-family: "Helvetica Neue", "Arial Black", sans-serif;
  color: #ffffff;
  text-align: center;
}

/* 上半片文字：顶边对齐容器，显示数字上半部分 */
.digit-text-top {
  top: 0;
}

/* 下半片文字：底边对齐容器，显示数字下半部分 */
.digit-text-bottom {
  bottom: 0;
}

.colon {
  width: 24rpx;
  height: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  margin-right: 8rpx;
}

.colon-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f5a623;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}
