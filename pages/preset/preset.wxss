/* pages/preset/preset.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx;
}
.header {
  margin-bottom: 24rpx;
}
.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
}
.sub {
  font-size: 24rpx;
  color: #9a9a9a;
  margin-top: 12rpx;
}

.card {
  background: #1a1a1a;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 16rpx;
}
.line {
  font-size: 26rpx;
  color: #cfcfcf;
  line-height: 1.8;
  margin-top: 4rpx;
}

.section-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 40rpx 0 16rpx;
}
.count-tag {
  font-size: 22rpx;
  color: #9a9a9a;
  background: #262626;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.preset-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.preset-item {
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 24rpx;
}
.preset-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.preset-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}
.preset-type {
  font-size: 22rpx;
  color: #f6ff5c;
  background: #2a2a2a;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.preset-params {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #cfcfcf;
  line-height: 1.6;
}
.preset-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6a6a6a;
}

.empty {
  margin-top: 24rpx;
  text-align: center;
  padding: 64rpx 0;
}
.empty-tip {
  font-size: 28rpx;
  color: #6a6a6a;
}
.empty-tip-sub {
  font-size: 22rpx;
  margin-top: 8rpx;
  color: #6a6a6a;
}
