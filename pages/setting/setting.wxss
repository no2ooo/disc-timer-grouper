/* pages/setting/setting.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx;
}
.header {
  margin-bottom: 24rpx;
}
.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
}

.row-card {
  background: #1a1a1a;
  border-radius: 24rpx;
  padding: 0 24rpx;
  margin-top: 16rpx;
}
.row-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  min-height: 88rpx;
}
.row-label {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
}
.row-label-red {
  font-size: 30rpx;
  color: #ff5c5c;
  font-weight: 500;
}
.row-value {
  font-size: 26rpx;
  color: #9a9a9a;
}
.divider {
  height: 1rpx;
  background: #262626;
}

.footer {
  margin-top: 80rpx;
  text-align: center;
  color: #6a6a6a;
  font-size: 22rpx;
}

.sign-row {
  background: rgba(246, 255, 92, 0.10);
  border-radius: 12rpx;
  margin: 8rpx 0;
  padding: 28rpx 16rpx;
}
.row-label-sign {
  color: #f6ff5c;
  font-weight: 700;
}
.row-value-sign {
  color: #f6ff5c;
}
