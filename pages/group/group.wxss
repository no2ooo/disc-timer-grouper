/* pages/group/group.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 64rpx;
}

.header {
  margin-bottom: 24rpx;
}
.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
}
.sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9a9a9a;
}

.ta {
  width: 100%;
  min-height: 280rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.6;
  background: transparent;
  padding: 8rpx 8rpx 16rpx;
}
.ph {
  color: #555;
}
.counter {
  font-size: 26rpx;
  color: #9a9a9a;
}
.op {
  display: flex;
  gap: 12rpx;
}
.opbtn {
  font-size: 24rpx;
  color: #f6ff5c;
  border: 1rpx solid #f6ff5c;
  border-radius: 999rpx;
  padding: 8rpx 22rpx;
}

/* 3 卡片 */
.cards {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 32rpx;
}
.group-card {
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
}
.card-yellow { background: #f6ff5c; color: #0a0a0a; }
.card-green  { background: #b5f25c; color: #0a0a0a; }
.card-blue   { background: #5cb8ff; color: #0a0a0a; }
.card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.15);
  padding-bottom: 12rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.dot-green { background: #b5f25c; }
.dot-blue  { background: #5cb8ff; }
.dot-red   { background: #ff5c5c; }
.card-title {
  font-size: 32rpx;
  font-weight: 800;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #0a0a0a;
}
.card-body {
  margin-top: 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.member {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #0a0a0a;
  cursor: pointer; /* 小程序忽略但无害,提示该元素可拖拽 */
}

/* 拖拽浮层:跟手的幽灵标签(left/top 由内联 style 提供) */
.drag-ghost {
  position: fixed;
  z-index: 999;
  pointer-events: none;
  background: #f6ff5c;
  color: #0a0a0a;
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.45);
  white-space: nowrap;
}
.empty {
  font-size: 24rpx;
  font-style: italic;
  margin-top: 8rpx;
  color: rgba(10,10,10,0.55);
}

.empty-state {
  margin-top: 48rpx;
  text-align: center;
}
.empty-tip {
  font-size: 28rpx;
  color: #6a6a6a;
}
.empty-tip-sub {
  font-size: 22rpx;
  margin-top: 12rpx;
  color: #6a6a6a;
}

/* 历史 */
.history {
  margin-top: 48rpx;
}
.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.clear-btn {
  font-size: 24rpx;
  color: #9a9a9a;
}
.hist-item {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.hist-meta {
  font-size: 24rpx;
  color: #9a9a9a;
}
.hist-preview {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.hist-pill {
  font-size: 22rpx;
  background: #262626;
  color: #f6ff5c;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* ============ 智能解析报名名单 ============ */
.roster-toggle {
  margin-top: 24rpx;
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.roster-toggle-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}
.roster-toggle-arrow {
  font-size: 24rpx;
  color: #f6ff5c;
}
.roster-box {
  margin-top: 16rpx;
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 20rpx;
}
.roster-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #262626;
  padding-top: 16rpx;
  margin-top: 8rpx;
}
.opbtn-primary {
  color: #0a0a0a;
  background: #f6ff5c;
  border: 1rpx solid #f6ff5c;
  border-radius: 999rpx;
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}

/* 解析结果卡片头部的性别统计 */
.card-stat {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(10,10,10,0.7);
  text-align: right;
  flex-shrink: 1;
}

/* 成员前的性别小图标(单 class,避免组合选择器) */
.gender {
  font-weight: 800;
  margin-right: 6rpx;
}
.gm { color: #1f6fd0; }
.gf { color: #d63a93; }
.gu { color: #888888; }
.mname {
  font-weight: 600;
}
